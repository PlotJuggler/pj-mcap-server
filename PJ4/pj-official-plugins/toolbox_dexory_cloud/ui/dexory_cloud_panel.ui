<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>DexoryCloudPanel</class>
 <widget class="QWidget" name="DexoryCloudPanel">
  <layout class="QVBoxLayout" name="rootLayout">
   <property name="spacing"><number>8</number></property>
   <property name="leftMargin"><number>10</number></property>
   <property name="topMargin"><number>10</number></property>
   <property name="rightMargin"><number>10</number></property>
   <property name="bottomMargin"><number>10</number></property>

   <!-- Connect row: URI combo + Connect + Certificate -->
   <item>
    <layout class="QHBoxLayout" name="connectRow">
     <item>
      <widget class="QLabel" name="labelUri">
       <property name="text"><string>Server:</string></property>
       <property name="minimumSize"><size><width>50</width><height>0</height></size></property>
      </widget>
     </item>
     <item>
      <widget class="PJ::ComboBox" name="comboUri">
       <property name="editable"><bool>true</bool></property>
       <property name="sizePolicy">
        <sizepolicy hsizetype="Expanding" vsizetype="Fixed"><horstretch>1</horstretch><verstretch>0</verstretch></sizepolicy>
       </property>
      </widget>
     </item>
     <item>
      <widget class="QPushButton" name="buttonConnect">
       <property name="text"><string/></property>
       <property name="toolTip"><string>Connect</string></property>
       <property name="iconSize"><size><width>20</width><height>20</height></size></property>
      </widget>
     </item>
     <item>
      <widget class="QPushButton" name="buttonRefresh">
       <property name="text"><string/></property>
       <property name="toolTip"><string>Refresh sequences</string></property>
       <property name="iconSize"><size><width>20</width><height>20</height></size></property>
      </widget>
     </item>
     <item>
      <widget class="QPushButton" name="buttonCert">
       <property name="text"><string/></property>
       <property name="toolTip"><string>Cert / API Key&#8230;</string></property>
       <property name="iconSize"><size><width>20</width><height>20</height></size></property>
      </widget>
     </item>
     <item>
      <!-- Time-based aggregation toggle. ON by default: the sequence list shows
           one row per continuous recording session (a partition's time-contiguous
           run of chunk files) instead of one row per file. Untick to see the
           individual chunk files. -->
      <widget class="QCheckBox" name="checkAggregate">
       <property name="text"><string>Aggregate</string></property>
       <property name="toolTip"><string>Group time-contiguous chunk files into one session row</string></property>
       <property name="checked"><bool>true</bool></property>
      </widget>
     </item>
     <item>
      <!-- Info/metadata panel toggle. Hidden by default; ticking it shows the
           Info column with the full (un-elided) metadata for the selection. -->
      <widget class="QCheckBox" name="checkShowInfo">
       <property name="text"><string>Info</string></property>
       <property name="toolTip"><string>Show the metadata / info panel</string></property>
       <property name="checked"><bool>false</bool></property>
      </widget>
     </item>
    </layout>
   </item>

   <!-- Three-column splitter: Sequences | Topics | Info -->
   <item>
    <widget class="QSplitter" name="mainSplitter">
     <property name="orientation"><enum>Qt::Horizontal</enum></property>
     <property name="childrenCollapsible"><bool>false</bool></property>

     <!-- ============ SEQUENCES COLUMN ============ -->
     <!-- QFrame (not QWidget) so the app QSS three-sided border paints; the
          border meets the mainSplitter handle on the right (see stylesheet). -->
     <widget class="QFrame" name="seqPanelContainer">
      <layout class="QVBoxLayout" name="seqLayout">
       <property name="spacing"><number>4</number></property>
       <property name="leftMargin"><number>0</number></property>
       <property name="topMargin"><number>0</number></property>
       <property name="rightMargin"><number>0</number></property>
       <property name="bottomMargin"><number>0</number></property>
       <item>
        <widget class="QLabel" name="seqHeader">
         <property name="text"><string>Sequences</string></property>
         <property name="font"><font><bold>true</bold></font></property>
        </widget>
       </item>
       <item>
        <layout class="QHBoxLayout" name="seqFilterRow">
         <property name="spacing"><number>4</number></property>
         <item>
          <widget class="QLineEdit" name="seqFilter">
           <property name="placeholderText"><string>Filter&#8230;</string></property>
           <property name="clearButtonEnabled"><bool>true</bool></property>
          </widget>
         </item>
         <item>
          <widget class="QPushButton" name="seqRegexToggle">
           <property name="text"><string>.*</string></property>
           <property name="checkable"><bool>true</bool></property>
           <property name="toolTip"><string>Use regular expression</string></property>
           <property name="maximumSize"><size><width>28</width><height>16777215</height></size></property>
          </widget>
         </item>
        </layout>
       </item>
       <!-- D8: additive prefix-hierarchy row. Hidden by default; shown only when
            the server advertises supports_file_hierarchy (the flat Dexory corpus
            keeps it hidden). The plugin populates comboPrefix with the "All"
            sentinel plus the distinct top-level slash-prefixes derived from the
            object-key names, and narrows the visible sequence rows by the pick. -->
       <item>
        <layout class="QHBoxLayout" name="prefixRow">
         <property name="spacing"><number>4</number></property>
         <item>
          <widget class="QLabel" name="labelPrefix">
           <property name="text"><string>Folder:</string></property>
           <property name="visible"><bool>false</bool></property>
           <property name="toolTip"><string>Browse by object-key prefix</string></property>
          </widget>
         </item>
         <item>
          <widget class="PJ::ComboBox" name="comboPrefix">
           <property name="visible"><bool>false</bool></property>
           <property name="toolTip"><string>Filter sequences by top-level prefix</string></property>
           <property name="sizePolicy">
            <sizepolicy hsizetype="Expanding" vsizetype="Fixed"><horstretch>0</horstretch><verstretch>0</verstretch></sizepolicy>
           </property>
          </widget>
         </item>
        </layout>
       </item>
       <!-- Generic date/time range picker: presets + from/to fields + calendar overlay -->
       <item>
        <widget class="DateRangePicker" name="datePicker">
         <property name="sizePolicy">
          <sizepolicy hsizetype="Preferred" vsizetype="Preferred"><horstretch>0</horstretch><verstretch>0</verstretch></sizepolicy>
         </property>
        </widget>
       </item>
       <!-- The sequence table and the Lua query editor share a DRAGGABLE
            vertical splitter. Its handle is the separator (grab-and-resize),
            styled by the app's global QSplitter::handle QSS (a 1px border-grey
            line that highlights on hover) exactly like the column splitters.
            Initial bias toward the table via verstretch (2 vs 1); the query
            editor starts compact and the user can drag the divider to taste. -->
       <item>
        <widget class="QSplitter" name="seqQuerySplitter">
         <property name="orientation"><enum>Qt::Vertical</enum></property>
         <property name="childrenCollapsible"><bool>false</bool></property>
         <widget class="QTableWidget" name="seqTable">
          <property name="sizePolicy">
           <sizepolicy hsizetype="Expanding" vsizetype="Expanding"><horstretch>0</horstretch><verstretch>2</verstretch></sizepolicy>
          </property>
          <property name="selectionMode"><enum>QAbstractItemView::ExtendedSelection</enum></property>
          <property name="selectionBehavior"><enum>QAbstractItemView::SelectRows</enum></property>
          <property name="editTriggers"><set>QAbstractItemView::NoEditTriggers</set></property>
          <attribute name="verticalHeaderVisible"><bool>false</bool></attribute>
         </widget>
         <widget class="QWidget" name="queryPane" native="true">
          <property name="sizePolicy">
           <sizepolicy hsizetype="Expanding" vsizetype="Expanding"><horstretch>0</horstretch><verstretch>1</verstretch></sizepolicy>
          </property>
          <layout class="QVBoxLayout" name="queryPaneLayout">
           <property name="leftMargin"><number>0</number></property>
           <property name="topMargin"><number>0</number></property>
           <property name="rightMargin"><number>0</number></property>
           <property name="bottomMargin"><number>0</number></property>
           <property name="spacing"><number>2</number></property>
           <!-- Basic | Advanced filter tabs. The ACTIVE tab decides which filter
                applies (the other's state is preserved but ignored). Basic: one
                dropdown per S3-key field. Advanced: the Lua query (moved here as-is).
                documentMode is REQUIRED for the tabs to span the pane width: a
                non-document QTabWidget hands its tab bar only the bar's own
                sizeHint (SE_TabWidgetTabBar), so no sizePolicy and no
                QTabBar::expanding can ever stretch the tabs. Qt resets
                expanding=false inside setDocumentMode(true); the host
                (widget_binding.cpp, QTabWidget branch) re-asserts it on apply. -->
           <item>
            <widget class="QTabWidget" name="filterTabs">
             <property name="sizePolicy">
              <sizepolicy hsizetype="Expanding" vsizetype="Expanding"><horstretch>0</horstretch><verstretch>1</verstretch></sizepolicy>
             </property>
             <property name="currentIndex"><number>0</number></property>
             <property name="documentMode"><bool>true</bool></property>
             <!-- Bordered-tab look (replaces the old "Metadata Filter" header as the
                  section delimiter). documentMode stays ON for full-width tabs; the
                  pane + per-tab borders are re-added via QSS, and drawBase=0 kills the
                  documentMode base line. Light-theme grays, matching the panel. -->
             <property name="styleSheet"><string notr="true">
QTabWidget::pane { border: 1px solid #a8a8a8; border-radius: 3px; top: -1px; }
QTabBar { qproperty-drawBase: 0; }
QTabBar::tab { border: 1px solid #a8a8a8; border-top-left-radius: 3px; border-top-right-radius: 3px; padding: 5px 12px; background: #e6e6e6; }
QTabBar::tab:selected { background: #ffffff; border-bottom-color: #ffffff; }
QTabBar::tab:!selected { background: #d7d7d7; margin-top: 2px; }
</string></property>
             <widget class="QWidget" name="basicTab">
              <attribute name="title"><string>Basic Metadata</string></attribute>
              <!-- QGridLayout (not QFormLayout) so rowstretch can distribute the
                   rows over the pane height; QFormLayout always top-packs. -->
              <layout class="QGridLayout" name="basicForm" rowstretch="1,1,1,1" columnstretch="0,1">
               <property name="leftMargin"><number>4</number></property>
               <property name="topMargin"><number>4</number></property>
               <property name="rightMargin"><number>4</number></property>
               <property name="bottomMargin"><number>4</number></property>
               <item row="0" column="0"><widget class="QLabel" name="labelCustomer"><property name="text"><string>Customer</string></property></widget></item>
               <item row="0" column="1"><widget class="PJ::ComboBox" name="filter_customer"><property name="sizePolicy"><sizepolicy hsizetype="Expanding" vsizetype="Fixed"><horstretch>1</horstretch><verstretch>0</verstretch></sizepolicy></property></widget></item>
               <item row="1" column="0"><widget class="QLabel" name="labelSite"><property name="text"><string>Site</string></property></widget></item>
               <item row="1" column="1"><widget class="PJ::ComboBox" name="filter_customer_site"><property name="sizePolicy"><sizepolicy hsizetype="Expanding" vsizetype="Fixed"><horstretch>1</horstretch><verstretch>0</verstretch></sizepolicy></property></widget></item>
               <item row="2" column="0"><widget class="QLabel" name="labelRobot"><property name="text"><string>Robot</string></property></widget></item>
               <item row="2" column="1"><widget class="PJ::ComboBox" name="filter_robot"><property name="sizePolicy"><sizepolicy hsizetype="Expanding" vsizetype="Fixed"><horstretch>1</horstretch><verstretch>0</verstretch></sizepolicy></property></widget></item>
               <item row="3" column="0"><widget class="QLabel" name="labelSource"><property name="text"><string>Source</string></property></widget></item>
               <item row="3" column="1"><widget class="PJ::ComboBox" name="filter_source"><property name="sizePolicy"><sizepolicy hsizetype="Expanding" vsizetype="Fixed"><horstretch>1</horstretch><verstretch>0</verstretch></sizepolicy></property></widget></item>
              </layout>
             </widget>
             <widget class="QWidget" name="advancedTab">
              <attribute name="title"><string>Advanced Metadata</string></attribute>
              <layout class="QVBoxLayout" name="advancedTabLayout">
               <property name="leftMargin"><number>4</number></property>
               <property name="topMargin"><number>4</number></property>
               <property name="rightMargin"><number>4</number></property>
               <property name="bottomMargin"><number>4</number></property>
               <property name="spacing"><number>2</number></property>
           <!-- Cursor-aware Key/Op/Value assist dropdowns. The plugin populates
                them per the caret position and inserts the picked token into the
                query at the caret (no popup completer). -->
           <item>
            <layout class="QHBoxLayout" name="queryAssistRow">
             <item>
              <widget class="PJ::ComboBox" name="keyCombo">
               <property name="sizePolicy">
                <sizepolicy hsizetype="Expanding" vsizetype="Fixed"><horstretch>1</horstretch><verstretch>0</verstretch></sizepolicy>
               </property>
               <property name="placeholderText"><string>Key</string></property>
              </widget>
             </item>
             <item>
              <widget class="PJ::ComboBox" name="opCombo">
               <property name="sizePolicy">
                <sizepolicy hsizetype="Fixed" vsizetype="Fixed"><horstretch>0</horstretch><verstretch>0</verstretch></sizepolicy>
               </property>
               <property name="maximumSize"><size><width>72</width><height>16777215</height></size></property>
               <property name="placeholderText"><string>Op</string></property>
              </widget>
             </item>
             <item>
              <widget class="PJ::ComboBox" name="valCombo">
               <property name="sizePolicy">
                <sizepolicy hsizetype="Expanding" vsizetype="Fixed"><horstretch>1</horstretch><verstretch>0</verstretch></sizepolicy>
               </property>
               <property name="placeholderText"><string>Value</string></property>
              </widget>
             </item>
            </layout>
           </item>
           <item>
            <widget class="QPlainTextEdit" name="lua_queryBar">
             <property name="sizePolicy">
              <sizepolicy hsizetype="Expanding" vsizetype="Expanding"><horstretch>0</horstretch><verstretch>1</verstretch></sizepolicy>
             </property>
             <property name="minimumSize"><size><width>0</width><height>72</height></size></property>
             <property name="styleSheet"><string notr="true">QPlainTextEdit { background-color: #ffffff; }</string></property>
            </widget>
           </item>
              </layout>
             </widget>
            </widget>
           </item>
          </layout>
         </widget>
        </widget>
       </item>
      </layout>
     </widget>

     <!-- ============ TOPICS COLUMN ============ -->
     <widget class="QFrame" name="topicPanelContainer">
      <layout class="QVBoxLayout" name="topicLayout">
       <property name="spacing"><number>4</number></property>
       <property name="leftMargin"><number>0</number></property>
       <property name="topMargin"><number>0</number></property>
       <property name="rightMargin"><number>0</number></property>
       <property name="bottomMargin"><number>0</number></property>
       <item>
        <widget class="QLabel" name="topicHeader">
         <property name="text"><string>Topics</string></property>
         <property name="font"><font><bold>true</bold></font></property>
        </widget>
       </item>
       <item>
        <layout class="QHBoxLayout" name="topicFilterRow">
         <property name="spacing"><number>4</number></property>
         <item>
          <widget class="QLineEdit" name="topicFilter">
           <property name="placeholderText"><string>Filter&#8230;</string></property>
           <property name="clearButtonEnabled"><bool>true</bool></property>
          </widget>
         </item>
         <item>
          <widget class="QPushButton" name="topicRegexToggle">
           <property name="text"><string>.*</string></property>
           <property name="checkable"><bool>true</bool></property>
           <property name="toolTip"><string>Use regular expression</string></property>
           <property name="maximumSize"><size><width>28</width><height>16777215</height></size></property>
          </widget>
         </item>
        </layout>
       </item>
       <item>
        <widget class="QTableWidget" name="topicTable">
         <property name="selectionMode"><enum>QAbstractItemView::ExtendedSelection</enum></property>
         <property name="selectionBehavior"><enum>QAbstractItemView::SelectRows</enum></property>
         <property name="editTriggers"><set>QAbstractItemView::NoEditTriggers</set></property>
         <attribute name="verticalHeaderVisible"><bool>false</bool></attribute>
        </widget>
       </item>
      </layout>
     </widget>

     <!-- ============ INFO COLUMN ============ -->
     <!-- Hidden for now (real S3-key sequences make the per-row Info text long
          and the column low-value vs the Sequences/Topics panels). A hidden
          QSplitter child collapses to zero width and hides its handle. The
          dataView/Info-header writes below are harmless no-ops while hidden;
          live download progress consequently surfaces only via the app's
          notification path, not this panel. Re-show by flipping visible=true. -->
     <widget class="QFrame" name="dataViewContainer">
      <property name="visible"><bool>false</bool></property>
      <layout class="QVBoxLayout" name="dataViewLayout">
       <property name="spacing"><number>4</number></property>
       <property name="leftMargin"><number>0</number></property>
       <property name="topMargin"><number>0</number></property>
       <property name="rightMargin"><number>0</number></property>
       <property name="bottomMargin"><number>0</number></property>
       <item>
        <!-- Info header row: title label + the additive Edit Tags button
             (Slice 6, Plan D Task 9). The button opens the modal tag editor
             sub-dialog via requestSubDialog(kTagDialogUi); it is disabled until
             a sequence is selected. The dataViewHeader objectName + semantics
             are unchanged. -->
        <layout class="QHBoxLayout" name="dataViewHeaderRow">
         <property name="spacing"><number>4</number></property>
         <item>
          <widget class="QLabel" name="dataViewHeader">
           <property name="text"><string>Info</string></property>
           <property name="font"><font><bold>true</bold></font></property>
          </widget>
         </item>
         <item>
          <spacer name="dataViewHeaderSpacer">
           <property name="orientation"><enum>Qt::Horizontal</enum></property>
           <property name="sizeHint" stdset="0"><size><width>40</width><height>0</height></size></property>
          </spacer>
         </item>
         <item>
          <widget class="QPushButton" name="buttonEditTags">
           <property name="text"><string>Edit Tags...</string></property>
           <property name="enabled"><bool>false</bool></property>
           <property name="toolTip"><string>Edit the selected sequence's tags</string></property>
          </widget>
         </item>
        </layout>
       </item>
       <item>
        <widget class="QPlainTextEdit" name="dataView">
         <property name="readOnly"><bool>true</bool></property>
         <property name="font">
          <font><family>Monospace</family><styleStrategy>PreferDefault</styleStrategy></font>
         </property>
         <property name="lineWrapMode"><enum>QPlainTextEdit::WidgetWidth</enum></property>
        </widget>
       </item>
      </layout>
     </widget>
    </widget>
   </item>

   <!-- Two-handle time range slider + Download button (PJ3 RangeSlider) -->
   <item>
    <layout class="QHBoxLayout" name="rangeRow">
     <item>
      <widget class="RangeSlider" name="rangeSlider">
       <property name="sizePolicy">
        <sizepolicy hsizetype="Expanding" vsizetype="Preferred"><horstretch>1</horstretch><verstretch>0</verstretch></sizepolicy>
       </property>
       <property name="minimumSize"><size><width>0</width><height>52</height></size></property>
       <property name="enabled"><bool>false</bool></property>
      </widget>
     </item>
     <item>
      <widget class="QPushButton" name="buttonFetch">
       <property name="text"><string>Download</string></property>
       <property name="minimumSize"><size><width>90</width><height>0</height></size></property>
      </widget>
     </item>
     <item>
      <widget class="QPushButton" name="buttonCancel">
       <property name="text"><string>Cancel</string></property>
      </widget>
     </item>
     <item>
      <widget class="QPushButton" name="buttonClose">
       <property name="text"><string>Close</string></property>
      </widget>
     </item>
    </layout>
   </item>
   <!-- No in-panel status strip: connection / import / error events surface in
        the app's top notification bell (reportMessage); live download progress
        shows in the Info panel during a fetch. -->
  </layout>
 </widget>
</ui>
