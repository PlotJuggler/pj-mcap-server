# Single source of truth for the supported ROS 2 distros.
# Format: <distro>:<base image>
#
# `ros:<distro>-ros-base` is the official Open Robotics image and is
# multi-arch (amd64 + arm64), unlike `osrf/ros:<distro>-desktop` which
# is amd64-only. We don't need the GUI tools that the desktop variant
# adds — only rclcpp, rosidl_typesupport_cpp, rosidl_typesupport_introspection_cpp
# and rosbag2_cpp, all present in ros-base.
humble:ros:humble-ros-base
iron:ros:iron-ros-base
jazzy:ros:jazzy-ros-base
rolling:ros:rolling-ros-base
