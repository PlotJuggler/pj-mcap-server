<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>CertDialog</class>
 <widget class="QDialog" name="CertDialog">
  <property name="windowTitle"><string>Server Certificate / API Key</string></property>
  <property name="minimumWidth"><number>520</number></property>
  <layout class="QVBoxLayout">
   <item>
    <!-- CredentialsEditor (PjUiLoader building block) provides the cert path +
         Browse, the API-key field + Show/Hide, a validation tick, and the
         plaintext-fallback checkbox. Its inner inputs keep the objectNames
         certPath / apiKey / allowInsecure so PanelEngine's sub-dialog harvester
         surfaces them to the plugin on OK. No apiKeyPattern is set: the editor
         is format-agnostic and defaults to "non-empty is valid". A deployment-specific
         key format can be supplied here once the real backend defines one. -->
    <widget class="CredentialsEditor" name="certContents"/>
   </item>
   <item>
    <widget class="QDialogButtonBox" name="buttonBox">
     <property name="standardButtons"><set>QDialogButtonBox::Cancel|QDialogButtonBox::Ok</set></property>
    </widget>
   </item>
  </layout>
 </widget>
</ui>
